# =====================================================
# FRONTEND - CONFIGURATION FIREBASE
# =====================================================

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_WEB_APP_ID=your_web_app_id
VITE_FIREBASE_ANDROID_APP_ID=your_android_app_id

# Backend API Configuration
VITE_API_URL_DEVELOPMENT=http://localhost:5000/api
VITE_API_URL_PRODUCTION=https://resto-custo.onrender.com/api
